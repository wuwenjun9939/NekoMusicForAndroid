<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules for Neko Music
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- 备份用户数据库（播放列表、搜索历史等） -->
        <include domain="database" path="app_database"/>

        <!-- 备份SharedPreferences（用户设置、主题设置等） -->
        <include domain="sharedpref" path="*.xml"/>

        <!-- 备份内部存储中的用户数据文件 -->
        <include domain="file" path="playlists/"/>
        <include domain="file" path="user_data/"/>
    </cloud-backup>

    <device-transfer>
        <!-- 设备传输时备份更多数据 -->
        <!-- 备份所有数据库 -->
        <include domain="database" path="."/>

        <!-- 备份所有SharedPreferences -->
        <include domain="sharedpref" path="."/>

        <!-- 备份内部存储中的所有用户数据 -->
        <include domain="file" path="playlists/"/>
        <include domain="file" path="user_data/"/>
        <include domain="file" path="settings/"/>
    </device-transfer>
</data-extraction-rules>