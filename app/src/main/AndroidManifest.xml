<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 普通应用权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.DOWNLOAD_WITHOUT_NOTIFICATION" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- OpenXR系统权限 -->
    <uses-permission android:name="org.khronos.openxr.permission.OPENXR_SYSTEM" />
    
    <!-- Pico VR 特定权限 -->
    <uses-permission android:name="com.picovr.permission.EYE_TRACKING" />
    <uses-permission android:name="com.picovr.permission.FACE_TRACKING" />

    <!-- VR设备特征 -->
    <uses-feature android:name="android.software.vr.mode" android:required="false" />
    <uses-feature android:name="android.hardware.vr.headtracking" android:required="false" />

    <application
        android:name=".NekoMusicApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Neko云音乐"
        android:usesCleartextTraffic="true">

        <!-- VR应用配置 -->
        <meta-data android:name="com.oculus.vr.support" android:value="true" />
        <meta-data android:name="com.oculus.vr.focusaware" android:value="true" />
        <meta-data android:name="com.oculus.ossplash.background" android:value="#000000" />
        
        <!-- PVR (Pico/Sparrow) VR配置 -->
        <meta-data android:name="com.pvr.vr.mode" android:value="vr" />
        <meta-data android:name="pvr.app.type" android:value="vr" />
        <meta-data android:name="pvr.display.orientation" android:value="180" />
        
        <!-- Pico OpenXR 特定元数据 -->
        <meta-data android:name="picovr.software.eye_tracking" android:value="false" />
        <meta-data android:name="picovr.software.face_tracking" android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Neko云音乐"
            android:launchMode="singleTask"
            android:alwaysRetainTaskState="true"
            android:screenOrientation="unspecified"
            android:configChanges="orientation|screenSize|keyboardHidden|uiMode|screenLayout|navigation"
            android:hardwareAccelerated="true"
            android:resizeableActivity="true"
            android:supportsPictureInPicture="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="com.google.intent.category.DAYDREAM" />
                <category android:name="com.oculus.intent.category.VR" />
                <category android:name="com.picovr.intent.category.VR" />
            </intent-filter>
            
            <!-- Oculus VR配置 -->
            <meta-data android:name="com.oculus.vr.support" android:value="true" />
            <meta-data android:name="com.oculus.vr.focusaware" android:value="true" />
            <meta-data android:name="com.oculus.ossplash.background" android:value="#000000" />
            
            <!-- PVR VR模式配置 -->
            <meta-data android:name="com.pvr.vr.mode" android:value="vr" />
            <meta-data android:name="pvr.app.type" android:value="vr" />
            <meta-data android:name="pvr.display.orientation" android:value="180" />
            <meta-data android:name="pvr.handtracking" android:value="true" />
            <meta-data android:name="pvr.controller" android:value="true" />
            
            <!-- VR应用特性 -->
            <meta-data android:name="android.software.vr.mode" android:value="true" />
            <meta-data android:name="android.hardware.vr.headtracking" android:value="true" />
        </activity>
        
        <service
            android:name=".MusicPlayerService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback"
            android:stopWithTask="false" />

        <!-- FuckChinaOS 悬浮窗服务 -->
        <service
            android:name=".floatwindow.FuckChinaOSFloatService"
            android:exported="false" />

        <!-- 桌面歌词服务 -->
        <service
            android:name=".desktoplyric.DesktopLyricService"
            android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- 音乐桌面组件 -->
        <receiver android:name=".widget.MusicWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.neko.music.action.PLAY_PAUSE" />
                <action android:name="com.neko.music.action.PREVIOUS" />
                <action android:name="com.neko.music.action.NEXT" />
                <action android:name="com.neko.music.action.UPDATE_WIDGET" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/music_widget_info" />
        </receiver>

        <!-- 桌面组件更新服务 -->
        <service android:name=".widget.MusicWidgetUpdateService"
            android:exported="false" />
    </application>

</manifest>